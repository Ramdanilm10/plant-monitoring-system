# =========================================================
# Application
# =========================================================
APP_ENV=production
PORT=8080
FRONTEND_DIST_PATH=../frontend/dist

# Digunakan hanya pada mode development
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# =========================================================
# PostgreSQL / Supabase
# =========================================================
SUPABASE_DB_HOST=example.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=example_database_user
SUPABASE_DB_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
SUPABASE_DB_NAME=postgres

# =========================================================
# Optional database backup connection
# =========================================================
# Isi jika proses backup menggunakan direct connection
# atau Supavisor session mode yang berbeda.
#
# Jika dikosongkan, script menggunakan konfigurasi
# SUPABASE_DB_* di atas.
SUPABASE_DB_BACKUP_HOST=
SUPABASE_DB_BACKUP_PORT=
SUPABASE_DB_BACKUP_USER=
SUPABASE_DB_BACKUP_PASSWORD=
SUPABASE_DB_BACKUP_NAME=

# =========================================================
# JWT authentication
# =========================================================
JWT_SECRET=GENERATE_A_RANDOM_SECRET_MINIMUM_32_BYTES
JWT_ISSUER=plant-monitoring-backend
JWT_AUDIENCE=plant-monitoring-web
JWT_TTL_MINUTES=120

# =========================================================
# Password hashing
# =========================================================
BCRYPT_COST=12

# =========================================================
# Blynk
# =========================================================
BLYNK_TOKEN=CHANGE_ME_BLYNK_TOKEN
BLYNK_SERVER=https://blynk.cloud
BLYNK_COLLECTOR_ENABLED=false
SENSOR_CRON=0 */30 * * * *

# =========================================================
# Direct device authentication
# =========================================================
DEVICE_CODE=ESP32-001

# Simpan SHA-256 hex dari API key perangkat.
# Jangan simpan API key plaintext.
DEVICE_API_KEY_SHA256=CHANGE_ME_DEVICE_API_KEY_SHA256

# =========================================================
# Plant mapping
# =========================================================
SOIL_1_PLANT_ID=1
SOIL_2_PLANT_ID=2